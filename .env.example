# Galago demo — miljövariabler (exempel)
# Kopiera till .env och fyll i dina värden.
# Källkoden läser variablerna via os.environ — ladda .env med t.ex.:
#   export $(grep -v '^#' .env | xargs)   # bash/zsh
# eller använd python-dotenv om du lägger till det som beroende.

# ── Webhook-notis vid feedback ──────────────────────────────────────────────
# Lämna tom för att stänga av webhook helt.
# Slack incoming webhook:   https://hooks.slack.com/services/T.../B.../...
# Discord webhook:          https://discord.com/api/webhooks/.../...
# Egen endpoint:            https://din-server.example.com/galago-feedback
DEMO_FEEDBACK_WEBHOOK_URL=

# ── Opt-in WAV-arkivering ───────────────────────────────────────────────────
# Katalog där WAV-kopior sparas när användaren kryssar i samtycke.
# Standard (om tom): demo/logs/wav_archive/
# Exempel absolut sökväg:
#   DEMO_WAV_ARCHIVE_DIR=/data/galago/wav_archive
DEMO_WAV_ARCHIVE_DIR=

# ── Säkerhetsgränser (upload_predict_gradio) ───────────────────────────────
# Max storlek på uppladdad WAV (MB).
DEMO_MAX_WAV_MB=50
# Rate limit: max antal körningar per tidsfönster (sekunder).
DEMO_RATE_MAX_CALLS=30
DEMO_RATE_WINDOW_SEC=60

# ── Hugging Face Space: vikter från Hub (valfritt lokalt) ───────────────────
# Om satt laddas filer ned till samma sökvägar som i repot innan modellen laddas.
# Skapa ett Model- eller Dataset-repo och ladda upp t.ex.:
#   models/detector/galago_detector_best.keras
#   models/all_species/galago_cnn_all_19classes_improved_best.keras
#   models/all_species/class_names_19.json
# (Valfritt: Malawi-profil + bättre plats-priors — se demo/README_spaces.md)
# GALAGO_HF_MODEL_REPO=ditt-användarnamn/galago-demo-vikter
# GALAGO_HF_MODEL_REVISION=main

# ── Gradio server ───────────────────────────────────────────────────────────
# Port för demot (testar 7860–7869 om porten är upptagen).
GRADIO_SERVER_PORT=7860
